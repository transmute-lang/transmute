---
source: src/dot.rs
expression: "Dot::new(&ast, &symbols).serialize()"
---
digraph ast {
ordering="out";
splines=false;
n0[label="{ {<struct>Point} | { <f0>x | number } | { <f1>y | number } }"][shape="record"][fontcolor="black"]
n1[label=""][shape="point"][fontcolor="black"]
n2[label="{ {<fn>dist() } | { <p0>from: Point | <p1>to: Point } }"][shape="record"][fontcolor="black"]
n2 -> n1[style="solid"][color="black"][arrowhead="none"]}
